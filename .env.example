# Local development only — not used in production.
# Copy to .env and adjust as needed.
#
# Production secrets are managed by Fly.io (fly secrets set)
# and Netlify (dashboard env vars). See README.md → Deployment.

# Admin password (default "admin" is fine for local dev)
POKERLOG_ADMIN_PASSWORD=admin

# JWT signing secret (insecure default is fine for local dev)
POKERLOG_JWT_SECRET=local-dev-secret

# JWT token lifetime in hours
POKERLOG_JWT_EXPIRE_HOURS=24

# Frontend API target (points at local backend)
VITE_API_BASE=http://localhost:8000

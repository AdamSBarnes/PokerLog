# ─── Backend (Fly.io) ───────────────────────────────────────
# Admin password for the single-user JWT auth
POKERLOG_ADMIN_PASSWORD=change-me

# JWT signing secret (use a long random string)
POKERLOG_JWT_SECRET=change-me-use-a-long-random-string

# JWT token lifetime in hours (default: 24)
POKERLOG_JWT_EXPIRE_HOURS=24

# Path to the SQLite database (inside the persistent volume on Fly.io)
POKER_SQLITE_PATH=/data/poker.sqlite

# Lock CORS to your frontend domain in production
POKERLOG_CORS_ORIGINS=https://your-site.netlify.app

# ─── Frontend (Netlify) ────────────────────────────────────
# Set in Netlify environment variables:
VITE_API_BASE=https://your-app.fly.dev
